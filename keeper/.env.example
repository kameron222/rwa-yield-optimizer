# ── RPC ────────────────────────────────────────────────────────────────────────
# Alchemy Base WebSocket URL — wss://base-mainnet.g.alchemy.com/v2/<API_KEY>
BASE_RPC_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Keeper wallet ───────────────────────────────────────────────────────────────
# Private key of the EOA that owns the Rebalancer (and the vault for harvest).
# Fund with enough ETH on Base for gas (~0.01 ETH covers weeks of operation).
KEEPER_PRIVATE_KEY=0xdeadbeef...

# ── Contract addresses (populate after deployment) ─────────────────────────────
VAULT_ADDRESS=0x0000000000000000000000000000000000000000
REBALANCER_ADDRESS=0x0000000000000000000000000000000000000000

# ── Discord alerts ─────────────────────────────────────────────────────────────
# Optional — omit to disable Discord notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_TOKEN

# ── Tuning ─────────────────────────────────────────────────────────────────────
# How often (ms) to poll shouldRebalance() — default 1 hour
REBALANCE_POLL_MS=3600000

# Large deposit/withdraw threshold in USDC that triggers immediate rebalance check
LARGE_FLOW_THRESHOLD_USDC=10000

# How often (ms) to run harvest — default 24 hours
HARVEST_INTERVAL_MS=86400000
